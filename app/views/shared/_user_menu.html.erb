<div class="user-menu-wrapper">
  <% if current_user %>
    <div class="user-avatar-circle" id="taiga-avatar-btn">
      <%= current_user.username[0].upcase %>
    </div>

    <div class="user-dropdown-menu" id="taiga-dropdown" style="display: none;">
      <div class="user-info-section">
        <span class="user-info-name"><%= current_user.username %></span>
        <span class="user-info-email"><%= current_user.email %></span>
      </div>

      <div class="dropdown-options-list">
        <%= button_to "Cerrar sesión", logout_path, method: :delete, class: "logout-button-link" %>
      </div>
    </div>
  <% else %>
    <%= button_to "Iniciar sesión con Google", '/auth/google_oauth2', method: :post, data: { turbo: false }, class: "btn-login" %>
  <% end %>
</div>

<script>
  document.addEventListener("turbo:load", function() {
    const btn = document.getElementById("taiga-avatar-btn");
    const menu = document.getElementById("taiga-dropdown");

    if (btn && menu) {
      btn.addEventListener("click", function(e) {
        e.stopPropagation();
        menu.style.display = (menu.style.display === "none") ? "block" : "none";
      });

      document.addEventListener("click", function(e) {
        if (!menu.contains(e.target)) {
          menu.style.display = "none";
        }
      });
    }
  });
</script>