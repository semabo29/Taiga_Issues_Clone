<div class="user-menu-wrapper">
  <% if current_user %>
    <input type="checkbox" id="user-menu-toggle" class="menu-toggle-checkbox" hidden>

    <label for="user-menu-toggle" class="menu-overlay"></label>

    <label for="user-menu-toggle" class="user-avatar-circle" id="taiga-avatar-btn">
      <%= current_user.username[0].upcase %>
    </label>

    <div class="user-dropdown-menu" id="taiga-dropdown">
      <div class="user-info-section">
        <span class="user-info-name"><%= current_user.username %></span>
        <span class="user-info-email"><%= current_user.email %></span>
        <%= link_to "View profile", user_path(current_user), style: "display: block; margin-top: 8px; color: #00b19d; text-decoration: none; font-size: 13px; font-weight: 500;" %>
      </div>

      <div class="dropdown-options-list">
        <%= button_to "Cerrar sesión", logout_path, method: :delete, class: "logout-button-link" %>
      </div>
    </div>
  <% else %>
    <%= button_to "Iniciar sesión con Google", '/auth/google_oauth2', method: :post, data: { turbo: false }, class: "btn-login" %>
  <% end %>
</div>