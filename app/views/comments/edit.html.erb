<div style="max-width: 600px; margin: 50px auto;">
  <h2>Edit Comment</h2>

  <%= form_with(model: [@comment.issue, @comment]) do |f| %>
    <%= f.text_area :content, style: "width: 100%; height: 100px; padding: 10px; margin-bottom: 15px;" %>
    
    <div style="display: flex; gap: 10px;">
      <%= f.submit "Save changes", class: "btn-create" %>
      <%= link_to "Cancel", issue_path(@comment.issue), style: "text-decoration: none; color: #888; align-self: center;" %>
    </div>
  <% end %>
</div>