<div class="taiga-main-container">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; border-bottom: 2px solid #eee; padding-bottom: 10px;">
    <div>
      <span style="color: #1fbdb8; font-weight: bold; font-size: 1.5rem;">#<%= @issue.id %></span>
      <h1 style="display: inline; margin-left: 10px; font-size: 1.8rem; color: #333;"><%= @issue.subject %></h1>
    </div>
    <%= link_to "×", issues_path, class: "close-btn", title: "Volver a la lista" %>
  </div>

  <div class="form-layout">
    <div class="form-left">
      <div style="background: #f9f9fb; padding: 20px; border-radius: 8px; border: 1px solid #e2eaf0; min-height: 200px;">
        <h3 style="color: #888; font-size: 12px; text-transform: uppercase; margin-top: 0;">Description</h3>
        <p style="color: #444; line-height: 1.6;"><%= @issue.description.presence || "No description provided." %></p>
      </div>
      
      <% if @issue.tags.any? %>
        <div style="margin-top: 20px;">
          <h3 style="color: #888; font-size: 12px; text-transform: uppercase;">Tags</h3>
          <div style="display: flex; gap: 10px; flex-wrap: wrap;">
            <% @issue.tags.each do |tag| %>
              <span style="background-color: <%= tag.color %>; color: white; padding: 4px 10px; border-radius: 3px; font-size: 12px; font-weight: bold;">
                <%= tag.name %>
              </span>
            <% end %>
          </div>
        </div>
      <% end %>

      <%# --- SECCIÓ: Attachments --- %>
      <div style="margin-top: 40px;">
        <h3 style="color: #4a5b6d; border-bottom: 1px solid #e2eaf0; padding-bottom: 10px;">Attachments</h3>
        
        <% if @issue.attachments.attached? %>
          <ul style="list-style: none; padding: 0;">
            <% @issue.attachments.each do |attachment| %>
              <li style="display: flex; align-items: center; justify-content: space-between; padding: 10px; border-bottom: 1px solid #f0f0f0;">
                <%# Enllaç per descarregar l'arxiu usant rails_blob_path %>
                <%= link_to attachment.filename, rails_blob_path(attachment, disposition: "attachment"), style: "color: #00b19d; text-decoration: none; font-weight: bold;" %>
                
                <%# Botó per esborrar l'arxiu específic %>
                <%= button_to "Delete", purge_attachment_issue_path(@issue, attachment_id: attachment.id), method: :delete, data: { turbo_confirm: "Are you sure?" }, style: "background-color: #E44057; color: white; border: none; padding: 5px 10px; border-radius: 3px; cursor: pointer;" %>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p style="color: #888; font-style: italic;">No files attached yet.</p>
        <% end %>
      </div>

      <div style="margin-top: 30px; display: flex; gap: 15px; align-items: center;">
        <%= link_to "EDIT ISSUE", edit_issue_path(@issue), style: "display: inline-flex; align-items: center; justify-content: center; padding: 0 20px; height: 40px; border-radius: 3px; font-weight: 600; font-size: 13px; text-decoration: none; color: #fff; background-color: #00b19d; cursor: pointer; border: none;" %>
        
        <%= button_to "DELETE ISSUE", @issue, method: :delete, data: { turbo_confirm: "Are you sure?" }, form: { style: "margin: 0; display: flex;" }, style: "display: inline-flex; align-items: center; justify-content: center; padding: 0 20px; height: 40px; border-radius: 3px; font-weight: 600; font-size: 13px; text-decoration: none; color: #fff; background-color: #E44057; cursor: pointer; border: none;" %>
      </div>
    </div>

    <div class="form-right">
      <div class="sidebar-box">
        <div class="status-select" style="text-align: center; background-color: <%= @issue.status&.color %>;">
          <%= @issue.status&.name&.upcase %>
        </div>

        <div class="attr-row">
          <span class="attr-label">Type</span>
          <span style="font-size: 13px; font-weight: bold;">
            <%= @issue.issue_type&.name %>
            <span class="color-dot" style="background-color: <%= @issue.issue_type&.color %>;"></span>
          </span>
        </div>

        <div class="attr-row">
          <span class="attr-label">Severity</span>
          <span style="font-size: 13px; font-weight: bold;">
            <%= @issue.severity&.name %>
            <span class="color-dot" style="background-color: <%= @issue.severity&.color %>;"></span>
          </span>
        </div>

        <div class="attr-row">
          <span class="attr-label">Priority</span>
          <span style="font-size: 13px; font-weight: bold;">
            <%= @issue.priority&.name %>
            <span class="color-dot" style="background-color: <%= @issue.priority&.color %>;"></span>
          </span>
        </div>
        
        <div class="attr-row" style="border-bottom: none;">
          <span class="attr-label">Deadline</span>
          <% is_overdue = @issue.deadline.present? && @issue.deadline < Date.today %>
          <span style="font-size: 13px; font-weight: bold; color: <%= is_overdue ? '#E44057' : '#333' %>;">
            <%= @issue.deadline ? @issue.deadline.strftime("%d %b %Y") : "None" %>
          </span>
        </div>
      </div>

      <div style="margin-top: 20px; text-align: center;">
        <%= link_to "← Back to list", issues_path, style: "color: #1fbdb8; text-decoration: none; font-size: 14px; font-weight: bold;" %>
      </div>
    </div>
  </div>
</div>