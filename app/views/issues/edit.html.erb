<div class="taiga-main-container">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
    <h1 style="font-family: 'Ubuntu-Medium', Arial, sans-serif; font-size: 2rem; color: #02202b; margin: 0;">
      Edit issue <span style="color: #1fbdb8;">#<%= @issue.id %></span>
    </h1>
    <%= link_to "×", @issue, class: "close-btn", title: "Cancelar y volver" %>
  </div>

  <%# Reutilizamos el formulario que ya tuneamos antes %>
  <%= render "form", issue: @issue %>

  <div style="margin-top: 20px; text-align: center;">
    <%= link_to "← Back to list", issues_path, style: "color: #1fbdb8; text-decoration: none; font-size: 14px;" %>
  </div>
</div>