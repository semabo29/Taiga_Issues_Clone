<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
  <h1 style="font-family: 'Ubuntu-Medium', Arial, sans-serif; font-size: 2.25rem; font-weight: 500; color: rgb(0, 138, 168); margin: 0;">Issues</h1>

  <div style="display: flex; gap: 10px; align-items: center;">
    <%= link_to "SETTINGS", settings_path, style: "color: #888; text-decoration: none; font-weight: bold; font-size: 13px; margin-right: 10px;" %>

    <%= link_to "+ NEW ISSUE", new_issue_path, class: "btn-new-issue", style: "padding: 8px 16px; font-size: 14px; text-transform: uppercase; display: flex; align-items: center;" %>

    <%= link_to bulk_new_issues_path, title: "Bulk insert", style: "background-color: #e2eaf0; width: 34px; height: 34px; border-radius: 4px; display: flex; align-items: center; justify-content: center; text-decoration: none; transition: background-color 0.2s;" do %>
      <div style="position: relative; width: 16px; height: 14px;">
        <div style="position: absolute; right: 0; top: 0; width: 14px; height: 2px; background-color: #4a5b6d;"></div>
        <div style="position: absolute; right: 0; top: 6px; width: 14px; height: 2px; background-color: #4a5b6d;"></div>
        <div style="position: absolute; right: 0; top: 12px; width: 14px; height: 2px; background-color: #4a5b6d;"></div>
        <div style="position: absolute; left: -5px; top: -7px; font-size: 17px; font-weight: bold; color: #4a5b6d; background-color: #e2eaf0; line-height: 1; padding: 2px;">+</div>
      </div>
    <% end %>
  </div>
</div>

<%# --- BARRA DE BÚSQUEDA Y FILTROS --- %>
<div style="background-color: #f9f9fb; padding: 15px; border-radius: 6px; margin-bottom: 20px; border: 1px solid #e2eaf0;">
  <%= form_with(url: issues_path, method: :get, local: true) do |f| %>
    <div style="display: flex; gap: 15px; align-items: flex-end; flex-wrap: wrap;">

      <%# Búsqueda de texto (Subject / Description) %>
      <div style="flex: 1; min-width: 200px;">
        <%= f.label :query, "Search in subject/description", style: "display: block; font-size: 11px; color: #888; text-transform: uppercase; margin-bottom: 5px; font-weight: bold;" %>
        <%= f.text_field :query, value: params[:query], placeholder: "Search...", class: "taiga-subject", style: "margin-bottom: 0; padding: 8px; font-size: 14px; width: 100%; box-sizing: border-box;" %>
      </div>

      <%# Filtro: Tipo %>
      <div>
        <%= f.label :issue_type_id, "Type", style: "display: block; font-size: 11px; color: #888; text-transform: uppercase; margin-bottom: 5px; font-weight: bold;" %>
        <%= f.collection_select :issue_type_id, IssueType.all, :id, :name, { include_blank: "All Types", selected: params[:issue_type_id] }, { style: "padding: 8px; border: 1px solid #1fbdb8; border-radius: 3px; background: white; min-width: 120px;" } %>
      </div>

      <%# Filtro: Severidad %>
      <div>
        <%= f.label :severity_id, "Severity", style: "display: block; font-size: 11px; color: #888; text-transform: uppercase; margin-bottom: 5px; font-weight: bold;" %>
        <%= f.collection_select :severity_id, Severity.all, :id, :name, { include_blank: "All Severities", selected: params[:severity_id] }, { style: "padding: 8px; border: 1px solid #1fbdb8; border-radius: 3px; background: white; min-width: 120px;" } %>
      </div>

      <%# Filtro: Prioridad %>
      <div>
        <%= f.label :priority_id, "Priority", style: "display: block; font-size: 11px; color: #888; text-transform: uppercase; margin-bottom: 5px; font-weight: bold;" %>
        <%= f.collection_select :priority_id, Priority.all, :id, :name, { include_blank: "All Priorities", selected: params[:priority_id] }, { style: "padding: 8px; border: 1px solid #1fbdb8; border-radius: 3px; background: white; min-width: 120px;" } %>
      </div>

      <%# Filtro: Estado %>
      <div>
        <%= f.label :status_id, "Status", style: "display: block; font-size: 11px; color: #888; text-transform: uppercase; margin-bottom: 5px; font-weight: bold;" %>
        <%= f.collection_select :status_id, Status.all, :id, :name, { include_blank: "All Statuses", selected: params[:status_id] }, { style: "padding: 8px; border: 1px solid #1fbdb8; border-radius: 3px; background: white; min-width: 120px;" } %>
      </div>

      <%# Botones de Acción %>
      <div style="display: flex; gap: 10px;">
        <%= f.submit "SEARCH", style: "background-color: #00b19d; color: white; padding: 0 15px; border: none; border-radius: 3px; font-weight: bold; cursor: pointer; height: 35px; font-size: 13px;" %>

        <%# Botón para limpiar filtros (simplemente recarga la página sin parámetros) %>
        <%= link_to "CLEAR", issues_path, style: "background-color: #e2eaf0; color: #333; padding: 0 15px; border: none; border-radius: 3px; font-weight: bold; text-decoration: none; display: inline-flex; align-items: center; justify-content: center; height: 35px; font-size: 13px; box-sizing: border-box;" %>
      </div>

    </div>
  <% end %>
</div>
<%# --- FIN BARRA DE BÚSQUEDA --- %>


<table class="taiga-table">
  <thead>
    <tr>
      <th style="width: 50px;"><%= sortable "issue_type_id", "Type" %></th>
      <th style="width: 80px;"><%= sortable "severity_id", "Severity" %></th>
      <th style="width: 80px;"><%= sortable "priority_id", "Priority" %></th>
      <th><%= sortable "id", "Issue" %></th>
      <th style="width: 120px;"><%= sortable "deadline", "Deadline" %></th>
      <th style="text-align: right;"><%= sortable "status_id", "Status" %></th>
      <th style="text-align: right;"><%= sortable "user_id", "Creator" %></th>
      <th style="text-align: right;"><%= sortable "assigned_to_id", "Assign to" %></th>
    </tr>
  </thead>
  <tbody>
    <% if @issues.any? %>
      <% @issues.each do |issue| %>
        <tr>
          <td><span class="color-dot" style="background-color: <%= issue.issue_type&.color || '#ccc' %>;" title="<%= issue.issue_type&.name %>"></span></td>
          <td><span class="color-dot" style="background-color: <%= issue.severity&.color || '#ccc' %>;" title="<%= issue.severity&.name %>"></span></td>
          <td><span class="color-dot" style="background-color: <%= issue.priority&.color || '#ccc' %>;" title="<%= issue.priority&.name %>"></span></td>
          <td>
            <%= link_to "##{issue.id}", issue, class: "issue-ref" %>
            <span style="margin-left:5px;"><%= issue.subject %></span>
          </td>
          <%# Columna Deadline con lógica de caducidad %>
          <td>
            <% if issue.deadline %>
              <% is_overdue = issue.deadline < Date.today %>
              <% expires_soon = issue.deadline >= Date.today && issue.deadline <= 7.days.from_now.to_date %>
              
              <div style="display: flex; flex-direction: column; gap: 4px;">
                <span style="font-size: 13px; font-weight: bold; color: <%= is_overdue ? '#E44057' : (expires_soon ? '#FF9100' : '#333') %>;">
                  <%= issue.deadline.strftime("%d %b %Y") %>
                </span>
                
                <% if is_overdue %>
                  <span style="background: #E44057; color: white; padding: 2px 6px; border-radius: 3px; font-size: 9px; font-weight: bold; display: inline-block; width: max-content;">OVERDUE</span>
                <% elsif expires_soon %>
                  <span style="background: #FFF0D9; color: #CC7300; padding: 2px 6px; border-radius: 3px; font-size: 9px; font-weight: bold; border: 1px solid #FFD8A1; display: inline-block; width: max-content;">DUE SOON</span>
                <% end %>
              </div>
            <% else %>
              <span style="color: #ccc; font-size: 13px;">-</span>
            <% end %>
          </td>
          <td style="text-align: right; font-weight: bold; color: <%= issue.status&.color || '#888' %>;">
            <%= issue.status&.name&.upcase || "NEW" %>
          </td>

          <%# --- COLUMNA: CREATOR --- %>
          <td style="text-align: right;">
            <%= link_to user_path(issue.user), style: "text-decoration: none; display: inline-flex; align-items: center; justify-content: flex-end; gap: 8px;" do %>
              <span style="color: #6a7c92; font-size: 13px;"><%= issue.user.username %></span>
              <div class="user-avatar-circle" style="background: #ccd5e0; color: white; width: 26px; height: 26px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: bold; overflow: hidden;">
                <% if issue.user.avatar.attached? %>
                  <%= image_tag issue.user.avatar, style: "width: 100%; height: 100%; object-fit: cover;" %>
                <% else %>
                  <%= issue.user.username[0].upcase %>
                <% end %>
              </div>
            <% end %>
          </td>

          <%# --- COLUMNA: ASSIGNED TO --- %>
          <td style="text-align: right;">
            <% if issue.assigned_to %>
              <%= link_to user_path(issue.assigned_to), style: "text-decoration: none; display: inline-flex; align-items: center; justify-content: flex-end; gap: 8px;" do %>
                <span style="color: #008aa8; font-size: 13px; font-weight: 500;"><%= issue.assigned_to.username %></span>
                <div class="user-avatar-circle" style="background: #00b19d; color: white; width: 26px; height: 26px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: bold; overflow: hidden;">
                  <% if issue.assigned_to.avatar.attached? %>
                    <%= image_tag issue.assigned_to.avatar, style: "width: 100%; height: 100%; object-fit: cover;" %>
                  <% else %>
                    <%= issue.assigned_to.username[0].upcase %>
                  <% end %>
                </div>
              <% end %>
            <% else %>
              <span style="color: #bbb; font-style: italic; font-size: 13px;">Unassigned</span>
            <% end %>
          </td>
        </tr>
      <% end %>
    <% else %>

      <tr>
        <td colspan="7" style="text-align: center; padding: 40px; color: #888;">
          No issues found matching your criteria.
        </td>
      </tr>

    <% end %>
  </tbody>
</table>