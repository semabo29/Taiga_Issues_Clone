<div style="display: flex; justify-content: space-between; align-items: center;">
  <h1 style="color: #02202b; font-weight: normal;">Issues</h1>
  <%= link_to "+ NEW ISSUE", new_issue_path, class: "btn-taiga" %>
</div>

<table class="taiga-table">
  <thead>
    <tr>
      <th>Type</th>
      <th>Severity</th>
      <th>Priority</th>
      <th>Issue</th>
      <th>Status</th>
      <th>Assign to</th>
    </tr>
  </thead>
  <tbody>
    <% @issues.each do |issue| %>
      <tr>
        <td><%= issue.try(:issue_type) || 'Bug' %></td> 
        <td><%= issue.severity %></td>
        <td><%= issue.priority %></td>
        <td>
          <%= link_to "##{issue.id}", issue, class: "issue-ref" %> 
          <%= issue.subject %>
        </td>
        <td><%= issue.status %></td>
        <td><%= issue.user.username %></td>
      </tr>
    <% end %>
  </tbody>
</table>