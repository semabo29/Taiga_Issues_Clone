<div class="taiga-main-container">
  
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
    <div style="width: 30px;"></div> 
    <h1 style="text-align: center; color: #02202b; margin: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif; font-weight: 300;">New bulk insert</h1>
    <%= link_to "✕", issues_path, class: "close-btn", title: "Close" %>
  </div>

  <%# Enviem les dades a la nova ruta bulk_create mitjançant POST %>
  <%= form_with url: bulk_create_issues_path, method: :post do |form| %>
    <div>
      <%= form.text_area :bulk_issues, class: "taiga-textarea", placeholder: "One item per line...", required: true, style: "min-height: 250px;" %>
    </div>

    <div style="text-align: right; margin-top: 10px;">
      <%= form.submit "SAVE", class: "btn-create", style: "width: auto; padding: 10px 30px; display: inline-block;" %>
    </div>
  <% end %>

</div>