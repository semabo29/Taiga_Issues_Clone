<%= form_with(model: issue) do |form| %>
  <% if issue.errors.any? %>
    <div style="color: red; padding: 10px; border: 1px solid red; margin-bottom: 20px;">
      <h2><%= pluralize(issue.errors.count, "error") %> prohibited this issue from being saved:</h2>
      <ul>
        <% issue.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-layout">
    <div class="form-left">
      <div>
        <%= form.text_field :subject, class: "taiga-input", placeholder: "Subject", required: true %>
      </div>

      <div>
        <span style="color: #1fbdb8; font-size: 14px; cursor: pointer;">Add tag +</span>
      </div>

      <div>
        <%= form.text_area :description, class: "taiga-textarea", placeholder: "Please add descriptive text to help others better understand this issue" %>
      </div>

      <div style="background: #f4f4f4; border: 2px dashed #ccc; padding: 30px; text-align: center; color: #888; border-radius: 4px;">
        Drop attachments here!
      </div>

      <div>
        <%= form.submit "CREATE", class: "btn-taiga btn-block" %>
      </div>
    </div>

    <div class="form-right">
      <div style="margin-bottom: 20px; border-bottom: 1px solid #eee; padding-bottom: 10px;">
        <span style="color: #888; font-size: 12px; text-transform: uppercase;">Assign to</span><br>
        <strong><%= current_user.username %></strong>
      </div>

      <div>
        <label style="color: #888; font-size: 12px;">TYPE</label>
        <%= form.select :issue_type, ['Bug', 'Question', 'Enhancement'], {}, class: "taiga-select" %>
      </div>

      <div>
        <label style="color: #888; font-size: 12px;">SEVERITY</label>
        <%= form.select :severity, ['Wishlist', 'Minor', 'Normal', 'Important', 'Critical'], {selected: 'Normal'}, class: "taiga-select" %>
      </div>

      <div>
        <label style="color: #888; font-size: 12px;">PRIORITY</label>
        <%= form.select :priority, ['Low', 'Normal', 'High'], {selected: 'Normal'}, class: "taiga-select" %>
      </div>

      <div>
        <label style="color: #888; font-size: 12px;">STATUS</label>
        <%= form.select :status, ['New', 'In progress', 'Ready for test', 'Closed', 'Needs info', 'Rejected', 'Postponed'], {selected: 'New'}, class: "taiga-select" %>
      </div>
    </div>
  </div>
<% end %>