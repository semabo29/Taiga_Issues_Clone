<%= form_with(model: issue) do |form| %>
  <div class="form-layout">
    
    <%# --- COLUMNA IZQUIERDA: Contenido --- %>
    <div class="form-left">
      <div>
        <%= form.text_field :subject, class: "taiga-subject", placeholder: "Subject", required: true %>
      </div>

      <div style="margin: 10px 0;">
        <span style="color: #1fbdb8; font-size: 14px; cursor: pointer; font-weight: bold;">Add tag +</span>
      </div>

      <div>
        <%= form.text_area :description, class: "taiga-textarea", placeholder: "Please add descriptive text to help others better understand this issue" %>
      </div>

      <%# Zona de Attachments (Estática por ahora para el diseño) %>
      <div style="background: #f4f8f9; border: 1px dashed #b0c1d4; padding: 40px; text-align: center; color: #6a7c92; font-size: 14px; margin-bottom: 20px;">
        <div style="background: #e2eaf0; padding: 10px; margin: -40px -40px 30px -40px; text-align: left; font-weight: bold;">
          0 Attachments <span style="float: right; cursor: pointer;">+</span>
        </div>
        Drop attachments here!
      </div>

      <div>
        <%= form.submit "CREATE", class: "btn-create" %>
      </div>
    </div>

    <%# --- COLUMNA DERECHA: Sidebar --- %>
    <div class="form-right">
      <%# Selector de Status dinámico %>
      <%= form.collection_select :status_id, Status.all, :id, :name, {}, { class: "status-select" } %>

      <div class="sidebar-box">
        <div style="margin-bottom: 20px; display: flex; align-items: center; gap: 10px;">
          <div style="background: #00b19d; width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
             <%# Inicial del usuario actual %>
             <span style="color: white; font-size: 16px; font-weight: bold;">
               <%= User.first.username[0].upcase %>
             </span>
          </div>
          <div style="font-size: 13px;">
            <span style="color: #1fbdb8; font-weight: bold; cursor: pointer;">Assign</span> or <br>
            <span style="color: #1fbdb8; font-weight: bold; cursor: pointer;">Assign to me</span>
          </div>
        </div>

        <%# Atributo: TYPE %>
        <div class="attr-row">
          <span class="attr-label">type</span>
          <div style="display: flex; align-items: center;">
            <%= form.collection_select :issue_type_id, IssueType.all, :id, :name, {}, { style: "border:none; background:transparent; text-align:right; -webkit-appearance: none; font-size: 13px;" } %>
            <span class="color-dot" style="background-color: <%= IssueType.first&.color || '#ccc' %>; margin-left: 8px;"></span>
          </div>
        </div>

        <%# Atributo: SEVERITY %>
        <div class="attr-row">
          <span class="attr-label">severity</span>
          <div style="display: flex; align-items: center;">
            <%= form.collection_select :severity_id, Severity.all, :id, :name, {}, { style: "border:none; background:transparent; text-align:right; -webkit-appearance: none; font-size: 13px;" } %>
            <span class="color-dot" style="background-color: <%= Severity.first&.color || '#ccc' %>; margin-left: 8px;"></span>
          </div>
        </div>

        <%# Atributo: PRIORITY %>
        <div class="attr-row" style="border-bottom: none;">
          <span class="attr-label">priority</span>
          <div style="display: flex; align-items: center;">
            <%= form.collection_select :priority_id, Priority.all, :id, :name, {}, { style: "border:none; background:transparent; text-align:right; -webkit-appearance: none; font-size: 13px;" } %>
            <span class="color-dot" style="background-color: <%= Priority.first&.color || '#ccc' %>; margin-left: 8px;"></span>
          </div>
        </div>
      </div>
    </div>

  </div>
<% end %>