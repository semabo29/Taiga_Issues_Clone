<div id="<%= dom_id issue %>">
  <p>
    <strong>Subject:</strong>
    <%= issue.subject %>
  </p>

  <p>
    <strong>Description:</strong>
    <%= issue.description %>
  </p>

  <p>
    <strong>Status:</strong>
    <%= issue.status %>
  </p>

  <p>
    <strong>Priority:</strong>
    <%= issue.priority %>
  </p>

  <p>
    <strong>Severity:</strong>
    <%= issue.severity %>
  </p>

  <p>
    <strong>User:</strong>
    <%= issue.user_id %>
  </p>

</div>
