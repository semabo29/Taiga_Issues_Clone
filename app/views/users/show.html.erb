<div class="profile-page-container">

  <%# --- SIDEBAR --- %>
  <div class="profile-sidebar">
    <div class="profile-avatar-large">
      <%= @user.username[0].upcase %>
    </div>

    <h1 class="profile-name"><%= @user.username %></h1>
    <p class="profile-email">@<%= @user.email.split('@').first %></p>

    <div class="profile-stats">
      <div class="stat-box">
        <span class="stat-number"><%= @open_issues_count || 0 %></span>
        <span class="stat-label">Open<br>Assigned<br>Issues</span>
      </div>
      <div class="stat-box">
        <span class="stat-number">0</span>
        <span class="stat-label">Watched<br>Issues</span>
      </div>
      <div class="stat-box">
        <span class="stat-number">0</span>
        <span class="stat-label">Comments</span>
      </div>
    </div>

    <div class="profile-bio">
      <% if @user.description.present? %>
        <p><%= @user.description %></p>
      <% else %>
        <p style="color: #bbb; font-style: italic;">No description provided yet.</p>
      <% end %>
    </div>

    <% if current_user == @user %>
      <%= link_to "EDIT PROFILE", edit_user_path(@user), class: "btn-edit-bio" %>
    <% end %>
  </div>

  <%# --- CONTENIDO PRINCIPAL --- %>
  <div class="profile-main-content">

    <div class="profile-tabs">
      <%= link_to "≡ Open Assigned Issues", user_path(@user, tab: "assigned"),
          class: "profile-tab #{@active_tab == 'assigned' ? 'active' : ''}" %>

      <% if current_user == @user %>
        <%= link_to "👁 Watched Issues", user_path(@user, tab: "watched"),
            class: "profile-tab #{@active_tab == 'watched' ? 'active' : ''}" %>
      <% end %>

      <%= link_to "💬 Comments", user_path(@user, tab: "comments"),
          class: "profile-tab #{@active_tab == 'comments' ? 'active' : ''}" %>
    </div>

    <%# --- CONTENEDORES DE CONTENIDO --- %>
    <div class="tab-content-area" style="padding: 20px 0;">
      <% case @active_tab %>
      <% when "assigned" %>
        <%= render "assigned_issues" %>

      <% when "watched" %>
        <div class="coming-soon-box">
          <p>👁 <strong>Watched Issues</strong></p>
          <p>Esta funcionalidad se implementará próximamente.</p>
        </div>

      <% when "comments" %>
        <div class="coming-soon-box">
          <p>💬 <strong>User Comments</strong></p>
          <p>El historial de comentarios estará disponible en la próxima versión.</p>
        </div>
      <% end %>
    </div>

  </div>
</div>

<%# --- ESTILOS EXTRA PARA EL AVISO Y PESTAÑAS --- %>
<style>
  .profile-tab {
    text-decoration: none;
    color: #666;
    display: inline-block;
    padding: 15px 20px;
    font-size: 14px;
    cursor: pointer;
  }
  .profile-tab:hover { background: #f0f0f0; }
  .profile-tab.active {
    color: #008aa8;
    border-bottom: 3px solid #008aa8;
    font-weight: 500;
  }

  .coming-soon-box {
    margin-top: 20px;
    padding: 60px;
    text-align: center;
    color: #666;
    background: #fdfdfd;
    border: 2px dashed #eee;
    border-radius: 8px;
  }
</style>