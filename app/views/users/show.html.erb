<div class="profile-page-container">

  <div class="profile-sidebar">
    <div class="profile-avatar-large">
      <%= @user.username[0].upcase %>
    </div>

    <h1 class="profile-name"><%= @user.username %></h1>
    <p class="profile-email">@<%= @user.email.split('@').first %></p>

    <div class="profile-stats">
      <div class="stat-box">
        <span class="stat-number">3</span>
        <span class="stat-label">Open<br>Assigned<br>Issues</span>
      </div>
      <div class="stat-box">
        <span class="stat-number">5</span>
        <span class="stat-label">Watched<br>Issues</span>
      </div>
      <div class="stat-box">
        <span class="stat-number">14</span>
        <span class="stat-label">Comments</span>
      </div>
    </div>

    <div class="profile-bio">
      <p>Faculty member at the Department of Service and Information System Engineering, UPC - Barcelona Tech.</p>
    </div>

    <% if current_user == @user %>
      <%= link_to "EDIT BIO", edit_user_path(@user), class: "btn-edit-bio" %>
    <% end %>
  </div>

  <div class="profile-main-content">

    <div class="profile-tabs">
      <div class="profile-tab active">≡ Open Assigned Issues</div>
      <% if current_user == @user %>
        <div class="profile-tab">👁 Watched Issues</div>
      <% end %>
      <div class="profile-tab">💬 Comments</div>
    </div>

    <div style="padding: 40px; text-align: center; color: #888; background: #f9fdfd; border: 1px dashed #ccc; border-radius: 4px;">
      <p style="margin: 0; font-size: 15px;">Las listas de issues y comentarios se renderizarán aquí próximamente...</p>
    </div>

  </div>
</div>